# CollegeOS Backend Environment Configuration
# Copy this file to .env and update with your values

# Server Configuration
PORT=5000
NODE_ENV=production

# ─── DATABASE (PostgreSQL) ────────────────────────────────────────────────────
#
# SUPABASE (recommended):
#   1. Go to your Supabase project → Settings → Database
#   2. Scroll to "Connection string" → select "URI" mode
#   3. Copy the string — it looks like:
#        postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#      OR the direct (non-pooler) connection:
#        postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
#   4. Paste it below (the direct connection is preferred for migrations)
#   5. SSL is enabled automatically when the URL contains "supabase.co/com"
#
# RENDER (auto-provided):
#   Render sets DATABASE_URL automatically for attached PostgreSQL databases.
#
DATABASE_URL=postgresql://postgres:[YOUR-SUPABASE-DB-PASSWORD]@db.vjxlpkqpwlgkdzheummp.supabase.co:5432/postgres

# Legacy SQLite path (only used locally if DATABASE_URL is not set)
# DATABASE_PATH=./database/college_app.db

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your-refresh-secret-here-change-in-production
REFRESH_TOKEN_EXPIRES_IN=7d

# Google OAuth (Optional - for Google login)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Frontend URL
# In production (Render) set this to the deployed Vercel URL:
# FRONTEND_URL=https://college-os.vercel.app
FRONTEND_URL=http://localhost:8080

# Web Scraping Configuration
SCRAPING_USER_AGENT=CollegeOS/1.0 (Educational Research)
SCRAPING_DELAY_MS=2000
REQUEST_TIMEOUT_MS=30000
CACHE_TTL_HOURS=24

# Exchange Rate API
# Used by financialCostService.js to refresh USD→INR (and other) rates.
# Free tier at https://www.exchangerate-api.com/ — register for a key.
# The service falls back to the latest stored DB rate when this is unreachable.
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest/USD

# College Data API Keys
# DATA_GOV_API_KEY / COLLEGE_SCORECARD_API_KEY — both are accepted by the scrapers.
# The College Scorecard API (https://api.data.gov/ed/collegescorecard/v1/schools)
# is the primary source for admissions stats, financial aid, and net-price data.
# Get your free key at: https://api.data.gov/signup/
# Provides: salary data, debt data, completion rates, net price
# Required: No (graceful fallback) | Recommended: Yes (adds 30% more fields)
# DATA_GOV_API_KEY=your_40_character_api_key_here
# COLLEGE_SCORECARD_API_KEY=your_40_character_api_key_here   # alias for DATA_GOV_API_KEY

# IPEDS API (Optional - currently using CSV bulk downloads)
# IPEDS_API_KEY=not_currently_used

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Reddit Scraper ────────────────────────────────────────────────────────────
# Reddit credentials are OPTIONAL.
#
# Without any credentials the scrapers use Reddit's free public JSON API
# (no sign-up required). Rate limit is ~10 req/min, so a full seed run is
# slower but fully functional.
#
# To use the faster OAuth path (60 req/min):
#   1. Register a "script" type app at https://www.reddit.com/prefs/apps
#   2. Set the three vars below (refresh token needs the "read" scope).
#
# REDDIT_CLIENT_ID=your_reddit_client_id
# REDDIT_CLIENT_SECRET=your_reddit_client_secret
# REDDIT_REFRESH_TOKEN=your_reddit_refresh_token

# ─── Google Gemini (values engine + Reddit post parser) ──────────────────────
# FREE tier — no credit card required. Get your key at https://aistudio.google.com/apikey
# Free limits: 1 500 requests/day, 15 RPM, 1 million tokens/minute (gemini-1.5-flash).
# Used by backend/src/services/valuesEngine.js and scraper/claudeParser.js.
GEMINI_API_KEY=AIza...

# ─── Python ML Service ────────────────────────────────────────────────────────
# URL of the Flask ML service (backend/ml-service/app.py).
# In production, run the service as a separate process on the same host or
# as a separate Railway / Render service and set this to its public URL.
ML_SERVICE_URL=http://127.0.0.1:5050
ML_SERVICE_TIMEOUT=8000

# ─── Scraper Scheduler ────────────────────────────────────────────────────────
# How many new feedback rows trigger an automatic model retrain (default: 100).
FEEDBACK_RETRAIN_THRESHOLD=100

# Enable scraping / ML cron jobs outside production (set to 'true' locally
# only if you want jobs to run; in production they start automatically).
# ENABLE_SCRAPING_JOBS=false
# ENABLE_ML_JOBS=false

# ─── Automated Data Pipeline (Python scrapers + orchestrator) ─────────────────
# REDDIT_USERNAME and REDDIT_PASSWORD are only needed for OAuth script-auth.
# They can be omitted entirely when using the public JSON API (no credentials).
# REDDIT_USERNAME=your_reddit_username
# REDDIT_PASSWORD=your_reddit_password

# Required for admissions_scraper.py, financial_scraper.py,
# and college_profile_scraper.py:
# DATA_GOV_API_KEY=your_40_character_key   # https://api.data.gov/signup/

# Python scraper schedule overrides (optional):
# POSTS_PER_SUBREDDIT=500
# REQUEST_DELAY_SEC=1.0
# ADMISSIONS_YEAR=2023
# FINANCIAL_YEAR=2022-23
# RETRAIN_THRESHOLD=100

