# CollegeOS Frontend Environment Configuration
# Copy this file to .env.local (local dev) or set these in your Vercel project settings.

# Backend API URL
# The code checks VITE_API_URL first, then falls back to VITE_API_BASE_URL.
# If NEITHER is set in Vercel, the app falls back to http://localhost:5000/api and
# ALL API calls will silently fail in production. Set at least one of these.
#
# For local development these default to http://localhost:5000/api (no change needed).
# For production (Vercel) set VITE_API_URL to your Render backend URL:
VITE_API_URL=https://collegeos.onrender.com/api
VITE_API_BASE_URL=https://collegeos.onrender.com/api

# Firebase Configuration
# Obtain these values from your Firebase project settings:
# https://console.firebase.google.com/ → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ─── Supabase (browser client — optional) ────────────────────────────────────
# Used by src/utils/supabase/client.ts for direct browser-to-Supabase queries.
# Found in: Supabase Dashboard → Project Settings → API
#   - Project URL              → VITE_SUPABASE_URL
#   - Anon / public key        → VITE_SUPABASE_ANON_KEY
#
# IMPORTANT: Vite requires the VITE_ prefix.
# The Next.js "NEXT_PUBLIC_" prefix does NOT work in this Vite app.
#
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# ─── OpenAI (backend only — set on Render, NOT Vercel) ───────────────────────
# OPENAI_API_KEY is consumed by the Node backend (backend/src/services/valuesEngine.js),
# NOT by the Vite frontend. Set it in your Render service environment, not here.
#
# It is called during onboarding (and on profile updates that change why_college_matters)
# to compute a 10-dimension values_vector via gpt-4o-mini, stored in
# student_profiles.values_vector. This vector drives the values_resonance component
# which is 30% of the total recommendation score. Without this key the values
# resonance score is 0 for every user and recommendations are purely
# academic/financial/location fit.
#
# Optional but strongly recommended for production:
#   OPENAI_API_KEY=sk-...    (set in Render → Environment)

