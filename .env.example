# CollegeOS Frontend Environment Configuration
# Copy this file to .env.local (local dev) or set these in your Vercel project settings.

# Backend API URL
# For local development this defaults to http://localhost:5000/api (no change needed).
# For production (Vercel) set this to your Render backend URL:
VITE_API_BASE_URL=https://collegeos.onrender.com/api

# Firebase Configuration
# Obtain these values from your Firebase project settings:
# https://console.firebase.google.com/ → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

