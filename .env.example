# CollegeOS Frontend Environment Configuration
# Copy this file to .env.local (local dev) or set these in your Vercel project settings.

# Backend API URL
# For local development this defaults to http://localhost:5000/api (no change needed).
# For production (Vercel) set this to your Render backend URL:
VITE_API_BASE_URL=https://collegeos.onrender.com/api
